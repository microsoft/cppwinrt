  </Target>
  <Target Name="CppWinRTPreprocessArmECThunk" Condition="'$(Platform_Arm64EC)'=='true'" BeforeTargets="_MARMASM" Outputs="$(IntDir)cached_thunks_arm64ec.pp" Inputs="..\strings\cached_thunks_arm64ec.asm">
