  <!-- ARM64: preprocess with cl.exe to expand #include "ksarm64.h" -->
  <Target Name="CppWinRTPreprocessArmThunk" Condition="'$(Platform_Arm64)'=='true'" BeforeTargets="_MARMASM" Outputs="$(IntDir)cached_thunks_arm64.pp" Inputs="..\strings\cached_thunks_arm64.asm">
