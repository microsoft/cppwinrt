    </ClCompile>
    <ClCompile Include="foundation.cpp" />
    <ClCompile Include="coroutines.cpp" />
    <ClCompile Include="source_location.cpp" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
