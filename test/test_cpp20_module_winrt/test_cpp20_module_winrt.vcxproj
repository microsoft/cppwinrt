  <!--
    This project builds the winrt C++20 module from the SDK projection.
    It produces:
      - winrt.ixx.ifc  (module interface, consumed via /reference by other projects)
      - winrt.ixx.obj  (module object, linked by other projects)
    The PreBuildEvent runs cppwinrt.exe to generate the projection headers
    and winrt.ixx into the shared output directory.
  -->
  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>$(ProjectDir)Generated Files;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
    </ClCompile>
    <PreBuildEvent>
      <Command>$(CppWinRTDir)cppwinrt -in sdk -out "$(ProjectDir)Generated Files" -module_filter Windows.Foundation -module_filter Windows.UI.Xaml -verbose</Command>
      <Message>Generating C++/WinRT SDK projection (filtered: Windows.Foundation, Windows.UI.Xaml)</Message>
    </PreBuildEvent>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
